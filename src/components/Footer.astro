---
const diensten = [
  { href: '/waterlekkage/', label: 'Waterlekkage' },
  { href: '/badkamerlekkage/', label: 'Badkamerlekkage' },
  { href: '/daklekkages/', label: 'Daklekkages' },
  { href: '/spouwmuur-lekkage/', label: 'Spouwmuurlekkage' },
  { href: '/gaslek/', label: 'Gaslek Detectie' },
  { href: '/vloer-leidingwerk-inspectie-zonder-hak-en-breekwerk/', label: 'Vloer Leidingwerk' },
];
const methoden = [
  { href: '/behandelmethodes/traceergas/', label: 'Traceergas' },
  { href: '/behandelmethodes/infraroodcamera/', label: 'Infraroodcamera' },
  { href: '/behandelmethodes/ultrasoon/', label: 'Ultrasoon' },
  { href: '/behandelmethodes/rookdetectie/', label: 'Rookdetectie' },
  { href: '/behandelmethodes/thermografie/', label: 'Thermografie' },
];
const locaties = [
  { href: '/lekdetectie-rotterdam/', label: 'Rotterdam' },
  { href: '/lekdetectie-den-haag/', label: 'Den Haag' },
  { href: '/lekdetectie-delft/', label: 'Delft' },
  { href: '/lekdetectie-dordrecht-binnenstad/', label: 'Dordrecht' },
  { href: '/lekdetectie-zoetermeer/', label: 'Zoetermeer' },
  { href: '/lekdetectie-leiden-centrum/', label: 'Leiden' },
];
---

<footer class="bg-neutral-900 text-neutral-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <div>
        <div class="mb-4">
          <img src="/logo_lekkageexpert_new.png" alt="Lekkage Expert" class="h-10 w-auto" />
        </div>
        <p class="text-sm leading-relaxed mb-4">
          Specialist in schadevrije lekdetectie. Wij vinden elke lekkage zonder hak- of breekwerk, in heel Zuid-Holland en omgeving.
        </p>
        <div class="space-y-2 text-sm">
          <div class="flex items-start gap-2">
            <svg class="w-4 h-4 mt-0.5 text-primary-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <a href="https://maps.google.com/?q=Vaasahof+29,+3067+DX+Rotterdam" target="_blank" rel="noopener" class="hover:text-white transition-colors">
              Vaasahof 29, 3067 DX Rotterdam
            </a>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-primary-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href="tel:0854001969" class="hover:text-white transition-colors">085-4001969</a>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-primary-400 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm6.231 17.733c-.826 2.35-3.045 3.867-5.569 3.867-1.438 0-2.818-.447-3.969-1.29l-4.412 1.156 1.18-4.297C4.399 15.814 4 14.461 4 13.045 4 8.05 8.05 4 13.045 4c2.447 0 4.747.952 6.476 2.681A9.1 9.1 0 0121.09 13.1c-.001 1.754-.486 3.453-1.405 4.949l.546.684z"/>
            </svg>
            <a href="https://wa.me/31612892333" class="hover:text-white transition-colors">WhatsApp: +31 6 12892333</a>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-primary-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <a href="mailto:info@lekkageexpert.nl" class="hover:text-white transition-colors">info@lekkageexpert.nl</a>
          </div>
        </div>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">Onze Diensten</h3>
        <ul class="space-y-2">
          {diensten.map(d => (
            <li>
              <a href={d.href} class="text-sm hover:text-white transition-colors">{d.label}</a>
            </li>
          ))}
          <li>
            <a href="/diensten/" class="text-sm text-primary-400 hover:text-primary-300 transition-colors font-medium">Alle diensten &rarr;</a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">Meetmethoden</h3>
        <ul class="space-y-2">
          {methoden.map(m => (
            <li>
              <a href={m.href} class="text-sm hover:text-white transition-colors">{m.label}</a>
            </li>
          ))}
          <li>
            <a href="/behandelmethodes/" class="text-sm text-primary-400 hover:text-primary-300 transition-colors font-medium">Alle methoden &rarr;</a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">Werkgebied</h3>
        <ul class="space-y-2">
          {locaties.map(l => (
            <li>
              <a href={l.href} class="text-sm hover:text-white transition-colors">{l.label}</a>
            </li>
          ))}
          <li>
            <a href="/locaties/" class="text-sm text-primary-400 hover:text-primary-300 transition-colors font-medium">Alle locaties &rarr;</a>
          </li>
        </ul>
        <div class="mt-6">
          <h3 class="text-white font-semibold mb-3">Informatie</h3>
          <ul class="space-y-2">
            <li><a href="/over-ons/" class="text-sm hover:text-white transition-colors">Over Ons</a></li>
            <li><a href="/second-opinion-lekkage/" class="text-sm hover:text-white transition-colors">Second Opinion</a></li>
            <li><a href="/begrippenlijst/" class="text-sm hover:text-white transition-colors">Begrippenlijst</a></li>
            <li><a href="/algemene-voorwaarden/" class="text-sm hover:text-white transition-colors">Algemene Voorwaarden</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="border-t border-neutral-800 pt-8 mb-8">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-6">
          <img
            src="/leerbedrijficon.png"
            alt="Erkend Leerbedrijf - Wij leiden vakmensen op"
            class="h-16 w-auto"
            loading="lazy"
          />
          <img
            src="/pinnen_ja_graag_400_225.png"
            alt="Pinnen ja graag - betalen per pin mogelijk"
            class="h-10 w-auto"
            loading="lazy"
          />
        </div>
        <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-neutral-500">
          {locaties.map(l => (
            <a href={l.href} class="flex items-center gap-1 hover:text-neutral-300 transition-colors">
              <svg class="w-3 h-3 text-primary-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
              </svg>
              {l.label}
            </a>
          ))}
          <a href="/locaties/" class="flex items-center gap-1 text-primary-400 hover:text-primary-300 transition-colors font-medium">
            + meer locaties
          </a>
        </div>
      </div>
    </div>

    <div class="border-t border-neutral-800 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-neutral-500">
        &copy; {new Date().getFullYear()} LekkageExpert. Alle rechten voorbehouden.
      </p>
      <div class="flex items-center gap-4 text-sm text-neutral-500">
        <a href="/algemene-voorwaarden/" class="hover:text-neutral-300 transition-colors">Voorwaarden</a>
        <span>|</span>
        <span>KvK: 94901716</span>
      </div>
    </div>
  </div>
</footer>
