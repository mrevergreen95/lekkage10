<style>
  vapi-widget, .vapi-custom-tooltip {
    position: fixed !important;
    z-index: 2147483647 !important;
  }

  .vapi-custom-tooltip {
    position: fixed;
    bottom: 90px;
    right: 25px;
    background-color: #ffffff;
    color: #111111;
    padding: 12px 16px;
    border-radius: 12px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    font-size: 14px;
    font-weight: 600;
    box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    border: 1px solid #eee;

    display: none;
    align-items: center;
    justify-content: space-between;
    gap: 15px;

    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .vapi-custom-tooltip.show {
    opacity: 1;
    transform: translateY(0);
    display: flex !important;
  }

  .vapi-custom-tooltip::after {
    content: '';
    position: absolute;
    bottom: -6px;
    right: 20px;
    border-width: 6px 6px 0;
    border-style: solid;
    border-color: #ffffff transparent transparent transparent;
    display: block;
    width: 0;
  }

  .tooltip-close-btn {
    background: none !important;
    border: none !important;
    padding: 0 !important;
    font-size: 22px !important;
    line-height: 1 !important;
    color: #999999 !important;
    cursor: pointer !important;
    display: flex !important;
    transition: color 0.2s ease !important;
  }

  .tooltip-close-btn:hover {
    color: #111111 !important;
  }

  @media (max-width: 480px) {
    vapi-widget {
      transform: scale(0.85) !important;
      transform-origin: bottom right !important;
    }

    .vapi-custom-tooltip {
      bottom: 80px !important;
      right: 15px !important;
      font-size: 13px;
      padding: 10px 14px;
    }
  }
</style>

<div class="vapi-custom-tooltip" id="vapi-tooltip">
  <span>👋 Last van lekkage? Praat met Sophie!</span>
  <button class="tooltip-close-btn" id="close-vapi-tooltip" aria-label="Sluiten">&times;</button>
</div>

<script src="https://unpkg.com/@vapi-ai/client-sdk-react/dist/embed/widget.umd.js" async type="text/javascript"></script>

<vapi-widget
  id="sophie-widget"
  public-key="8d28668d-bef6-4ef3-a409-4d08ed875863"
  assistant-id="52961968-163f-4bb5-9996-be79ba6451d6"
  mode="voice"
  size="compact"
  theme="light"
  position="bottom-right"
  button-base-color="#007AFF"
  button-accent-color="#FFFFFF"
  main-label="Bel AI expert"
  start-button-text="Start gesprek"
  end-button-text="Ophangen"
></vapi-widget>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const widget = document.getElementById('sophie-widget');
    const tooltip = document.getElementById('vapi-tooltip');
    const closeBtn = document.getElementById('close-vapi-tooltip');

    if (tooltip) {
      setTimeout(() => {
        tooltip.style.display = 'flex';
        setTimeout(() => {
          tooltip.classList.add('show');
        }, 50);
      }, 8000);
    }

    if (closeBtn && tooltip) {
      closeBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        tooltip.classList.remove('show');
        setTimeout(() => { tooltip.style.display = 'none'; }, 600);
      });
    }

    if (widget) {
      widget.addEventListener('click', () => {
        widget.setAttribute('main-label', 'Sophie AI Expert');

        if (tooltip) {
          tooltip.classList.remove('show');
          setTimeout(() => { tooltip.style.display = 'none'; }, 600);
        }
      });
    }

    window.addEventListener('vapi:call-start', () => {
      widget.setAttribute('main-label', 'Sophie AI Expert');
      if (tooltip) tooltip.style.display = 'none';
    });
  });
</script>
