---
import Layout from '../../layouts/Layout.astro';
import LeadForm from '../../components/LeadForm';
---

<Layout
  title="Contact – Lekkage Expert Rotterdam | 085-4001969"
  description="Neem contact op met Lekkage Expert. Bel 085-4001969, stuur een WhatsApp of gebruik ons contactformulier. 24/7 bereikbaar voor spoedgevallen."
>
  <div class="bg-neutral-50 border-b border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <h1 class="text-4xl font-bold text-neutral-900 mb-3">Contact</h1>
      <p class="text-xl text-neutral-600">Wij zijn 24/7 bereikbaar voor uw lekkageprobleem.</p>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <div>
        <h2 class="text-2xl font-bold text-neutral-900 mb-6">Direct contact opnemen</h2>

        <div class="space-y-4 mb-10">
          <a href="tel:0854001969" class="flex items-center gap-4 p-5 bg-primary-50 rounded-2xl border border-primary-100 hover:bg-primary-100 transition-colors group">
            <div class="w-12 h-12 bg-primary-600 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <div class="font-bold text-neutral-900">Telefonisch</div>
              <div class="text-primary-600 text-lg font-semibold">085-4001969</div>
              <div class="text-sm text-neutral-500">Ma-Vr 08:00–18:00 | Za 09:00–16:00 | Spoed 24/7</div>
            </div>
          </a>

          <a href="https://wa.me/31612892333" class="flex items-center gap-4 p-5 bg-secondary-50 rounded-2xl border border-secondary-100 hover:bg-secondary-100 transition-colors">
            <div class="w-12 h-12 bg-secondary-600 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm6.231 17.733c-.826 2.35-3.045 3.867-5.569 3.867-1.438 0-2.818-.447-3.969-1.29l-4.412 1.156 1.18-4.297C4.399 15.814 4 14.461 4 13.045 4 8.05 8.05 4 13.045 4c2.447 0 4.747.952 6.476 2.681A9.1 9.1 0 0121.09 13.1c-.001 1.754-.486 3.453-1.405 4.949l.546.684z"/>
              </svg>
            </div>
            <div>
              <div class="font-bold text-neutral-900">WhatsApp</div>
              <div class="text-secondary-600 text-lg font-semibold">+31 6 12892333</div>
              <div class="text-sm text-neutral-500">Stuur een bericht, wij reageren snel</div>
            </div>
          </a>

          <a href="mailto:info@lekkageexpert.nl" class="flex items-center gap-4 p-5 bg-neutral-50 rounded-2xl border border-neutral-200 hover:bg-neutral-100 transition-colors">
            <div class="w-12 h-12 bg-neutral-700 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <div class="font-bold text-neutral-900">E-mail</div>
              <div class="text-neutral-700 text-lg font-semibold">info@lekkageexpert.nl</div>
              <div class="text-sm text-neutral-500">Reactie binnen 24 uur op werkdagen</div>
            </div>
          </a>
        </div>

        <div class="bg-white rounded-2xl border border-neutral-200 p-6">
          <h3 class="font-bold text-neutral-900 mb-3">Bezoekadres</h3>
          <p class="text-neutral-700 mb-1">Lekkage Expert</p>
          <p class="text-neutral-700 mb-1">Vaasahof 29</p>
          <p class="text-neutral-700 mb-4">3067 DX Rotterdam</p>
          <a
            href="https://maps.google.com/?q=Vaasahof+29,+3067+DX+Rotterdam"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-2 text-primary-600 font-medium hover:text-primary-700 transition-colors text-sm"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Open in Google Maps
          </a>
        </div>
      </div>

      <div>
        <h2 class="text-2xl font-bold text-neutral-900 mb-6">Offerte aanvragen</h2>
        <LeadForm client:load />
      </div>
    </div>
  </div>
</Layout>
