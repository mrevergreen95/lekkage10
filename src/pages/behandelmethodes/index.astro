---
import Layout from '../../layouts/Layout.astro';

const methods = [
  {
    slug: 'traceergas',
    title: 'Traceergas',
    icon: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
    description: 'Nauwkeurige lokalisatie van lekken in water- en gasleidingen tot op de centimeter met inert gasmengsel.',
  },
  {
    slug: 'infraroodcamera',
    title: 'Infraroodcamera',
    icon: 'M15 10l4.553-2.069A1 1 0 0121 8.845v6.31a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h10a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z',
    description: 'Thermografische inspectie met warmtebeeldcamera brengt onzichtbare vochtplekken en temperatuurafwijkingen in beeld.',
  },
  {
    slug: 'ultrasoon',
    title: 'Ultrasoon',
    icon: 'M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3',
    description: 'Detectie van microlekken via ultrasone geluidsfrequenties die ontstaan bij turbulent ontsnapbaar gas of vloeistof.',
  },
  {
    slug: 'rookdetectie',
    title: 'Rookdetectie',
    icon: 'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z',
    description: 'Niet-giftige testrook maakt lekkages, scheuren en ongewenste verbindingen in riool- en afvoersystemen direct zichtbaar.',
  },
  {
    slug: 'thermografie',
    title: 'Thermografie',
    icon: 'M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v10m0 0h10m-10 0H5m14 0v4a2 2 0 01-2 2H9m8-6H9m0 6v4m0 0H5a2 2 0 01-2-2v-4m0 0h16',
    description: 'Professionele warmtebeeldinspectie door gecertificeerde thermografen, inclusief volledig thermografisch rapport.',
  },
  {
    slug: 'akoestisch',
    title: 'Akoestische Detectie',
    icon: 'M15.536 8.464a5 5 0 010 7.072M12 6a7 7 0 010 12M8.464 8.464a5 5 0 000 7.072M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    description: 'Lokalisatie van waterlekkages via het kenmerkende geluidssignaal dat een lek produceert, met correlatie-apparatuur.',
  },
  {
    slug: 'drukproef',
    title: 'Drukproef',
    icon: 'M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z',
    description: 'Water- of luchtdrukproef toont objectief aan of een leidinginstallatie lekvrij is, conform NEN-normen met officieel protocol.',
  },
  {
    slug: 'endoscopie',
    title: 'Endoscopie',
    icon: 'M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7',
    description: 'Flexibele camera-inspectie biedt direct visueel inzicht in de binnenkant van leidingen, inclusief digitale beeldrapportage.',
  },
  {
    slug: 'kleurstof',
    title: 'Kleurstof Detectie',
    icon: 'M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01',
    description: 'Biologisch afbreekbare tracervloeistof maakt lekpaden en systeemverbindingen direct zichtbaar en fotografisch bewijsbaar.',
  },
  {
    slug: 'rioolcamera',
    title: 'Rioolcamera',
    icon: 'M15 10l4.553-2.069A1 1 0 0121 8.845v6.31a1 1 0 01-1.447.894L15 14M5 18H3a2 2 0 01-2-2V8a2 2 0 012-2h3.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0111.07 3h1.86a2 2 0 011.664.89l.812 1.22A2 2 0 0017.07 6H19a2 2 0 012 2v8a2 2 0 01-2 2h-2',
    description: 'Zelfrijdende of handgeleide camera inspecteert riool- en afvoerleidingen volledig met sonde-lokalisatie boven maaiveld.',
  },
  {
    slug: 'uv-luminaat',
    title: 'UV-Luminescentie',
    icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
    description: 'Fluorescerende tracervloeistof licht op onder UV-licht en onthult lekpaden die met het blote oog niet zichtbaar zijn.',
  },
  {
    slug: 'vochtmeting',
    title: 'Vochtmeting',
    icon: 'M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z',
    description: 'Professionele vochtmeting met capacitieve, naald- en microgolfsensoren brengt vochtschade nauwkeurig in kaart met rapport.',
  },
];

const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Meetmethoden Lekdetectie – Lekkage Expert',
  description: 'Overzicht van alle professionele lekdetectie-meetmethoden van Lekkage Expert in Zuid-Holland.',
  numberOfItems: methods.length,
  itemListElement: methods.map((m, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: m.title,
    url: `https://www.lekkageexpert.nl/behandelmethodes/${m.slug}/`,
  })),
};
---
<Layout
  title="Onze Meetmethoden – Lekdetectie Technieken | Lekkage Expert"
  description="Overzicht van alle 12 professionele lekdetectiemethoden van Lekkage Expert: van traceergas en thermografie tot rioolcamera en drukproef. Altijd schadevrij."
  schema={schemaData}
>
  <!-- Hero -->
  <div class="relative bg-gradient-to-br from-primary-950 via-primary-900 to-primary-800 overflow-hidden">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <nav class="text-primary-300 text-sm mb-6 flex items-center gap-2">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span>/</span>
        <span class="text-white">Meetmethoden</span>
      </nav>
      <div class="max-w-3xl">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
          Onze Meetmethoden
        </h1>
        <p class="text-xl text-primary-200 leading-relaxed mb-8">
          Lekkage Expert beschikt over twaalf professionele detectiemethoden waarmee wij elke lekkage opsporen – volledig schadevrij en zonder hak- of breekwerk. Wij combineren technieken op maat van uw situatie voor de meest nauwkeurige diagnose.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="tel:0854001969"
            class="inline-flex items-center gap-2 bg-secondary-500 hover:bg-secondary-400 text-white font-semibold px-6 py-3 rounded-xl transition-colors"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            Bel direct: 085-4001969
          </a>
          <a
            href="/contact/"
            class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white font-semibold px-6 py-3 rounded-xl transition-colors border border-white/20"
          >
            Offerte aanvragen
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Intro strip -->
  <div class="bg-secondary-50 border-b border-secondary-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-wrap items-center gap-6 text-sm text-neutral-700">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-secondary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          <span>Altijd schadevrij – geen hak- of breekwerk</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-secondary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          <span>Gecertificeerde technici en meetapparatuur</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-secondary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          <span>Rapport na elk onderzoek</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-secondary-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
          <span>Actief in heel Zuid-Holland</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Methods grid -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl font-extrabold text-neutral-900 mb-4">
        12 Professionele Detectiemethoden
      </h2>
      <p class="text-lg text-neutral-600 max-w-2xl mx-auto leading-relaxed">
        Elke leksituatie vraagt om een andere aanpak. Onze technici selecteren altijd de meest effectieve combinatie van methoden voor uw specifieke probleem.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {methods.map(method => (
        <a
          href={`/behandelmethodes/${method.slug}/`}
          class="group bg-white border border-neutral-200 rounded-2xl p-6 hover:border-primary-300 hover:shadow-lg transition-all duration-200"
        >
          <div class="w-12 h-12 bg-primary-50 group-hover:bg-primary-100 rounded-xl flex items-center justify-center mb-4 transition-colors">
            <svg class="w-6 h-6 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={method.icon} />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-neutral-900 mb-2 group-hover:text-primary-700 transition-colors">
            {method.title}
          </h3>
          <p class="text-sm text-neutral-600 leading-relaxed mb-4">
            {method.description}
          </p>
          <span class="inline-flex items-center gap-1 text-sm font-semibold text-primary-700 group-hover:gap-2 transition-all">
            Meer informatie
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>

  <!-- How we work section -->
  <div class="bg-neutral-50 border-t border-neutral-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl font-extrabold text-neutral-900 mb-6">
            Hoe kiezen wij de juiste methode?
          </h2>
          <div class="space-y-5">
            <div class="flex gap-4">
              <div class="w-8 h-8 bg-primary-700 text-white rounded-full flex items-center justify-center font-bold text-sm flex-shrink-0 mt-0.5">1</div>
              <div>
                <h3 class="font-semibold text-neutral-900 mb-1">Intake en probleeminventarisatie</h3>
                <p class="text-neutral-600 text-sm leading-relaxed">Wij stellen gerichte vragen over de aard, locatie en duur van de lekkage om al voor het bezoek een gerichte methodenselectie te kunnen maken.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-8 h-8 bg-primary-700 text-white rounded-full flex items-center justify-center font-bold text-sm flex-shrink-0 mt-0.5">2</div>
              <div>
                <h3 class="font-semibold text-neutral-900 mb-1">Inspectie op locatie</h3>
                <p class="text-neutral-600 text-sm leading-relaxed">Onze technicus beoordeelt ter plaatse het type constructie, de leidingmaterialen en de omvang van het probleem om de optimale aanpak te bepalen.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-8 h-8 bg-primary-700 text-white rounded-full flex items-center justify-center font-bold text-sm flex-shrink-0 mt-0.5">3</div>
              <div>
                <h3 class="font-semibold text-neutral-900 mb-1">Gerichte detectie met de juiste methode</h3>
                <p class="text-neutral-600 text-sm leading-relaxed">Wij zetten de meest geschikte methode(n) in en combineren technieken waar dat de nauwkeurigheid vergroot – altijd zonder schade aan uw woning.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-8 h-8 bg-primary-700 text-white rounded-full flex items-center justify-center font-bold text-sm flex-shrink-0 mt-0.5">4</div>
              <div>
                <h3 class="font-semibold text-neutral-900 mb-1">Rapport en hersteladvies</h3>
                <p class="text-neutral-600 text-sm leading-relaxed">Na de detectie ontvangt u een helder rapport met de bevindingen, de exacte lekplek en een concreet advies voor herstel – bruikbaar voor uw aannemer en verzekeraar.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="relative">
          <img
            src="/installerwithcustomer_lekkageexxpert.png"
            alt="Lekkage Expert technicus aan het werk"
            class="rounded-2xl shadow-xl w-full object-cover aspect-[4/3] object-top"
            loading="lazy"
          />
          <div class="absolute -bottom-4 -left-4 bg-white rounded-xl shadow-lg p-4 border border-neutral-100">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 bg-secondary-100 rounded-full flex items-center justify-center">
                <svg class="w-5 h-5 text-secondary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <div class="font-bold text-neutral-900 text-sm">Gecertificeerd</div>
                <div class="text-xs text-neutral-500">NEN-EN ISO 9712</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="bg-primary-950 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 text-center">
      <h2 class="text-3xl font-extrabold mb-4">Lekkage? Wij helpen u vandaag nog.</h2>
      <p class="text-primary-200 text-lg mb-8 max-w-xl mx-auto">
        Neem direct contact op voor een vrijblijvend adviesgesprek of plan een inspectie in. Onze technici zijn beschikbaar in heel Zuid-Holland.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="tel:0854001969"
          class="inline-flex items-center gap-2 bg-secondary-500 hover:bg-secondary-400 text-white font-semibold px-8 py-4 rounded-xl transition-colors text-lg"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          085-4001969
        </a>
        <a
          href="https://wa.me/31612892333"
          class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 text-white font-semibold px-8 py-4 rounded-xl transition-colors border border-white/20 text-lg"
        >
          WhatsApp ons
        </a>
      </div>
    </div>
  </div>
</Layout>
