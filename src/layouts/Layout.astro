---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
import JsonLd from '../components/JsonLd.astro';

interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
  ogImage?: string;
  schema?: Record<string, unknown>;
  noIndex?: boolean;
}

const {
  title,
  description,
  canonicalUrl = Astro.url.href,
  ogImage = '',
  schema,
  noIndex = false,
} = Astro.props;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Lekkage Expert',
  description: 'Specialist in schadevrije lekdetectie. Wij vinden elke lekkage zonder hak- of breekwerk.',
  url: 'https://www.lekkageexpert.nl',
  telephone: '+31854001969',
  email: 'info@lekkageexpert.nl',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Vaasahof 29',
    addressLocality: 'Rotterdam',
    postalCode: '3067 DX',
    addressCountry: 'NL',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 51.9244,
    longitude: 4.4777,
  },
  areaServed: ['Rotterdam', 'Den Haag', 'Delft', 'Dordrecht', 'Leiden', 'Zoetermeer', 'Zuid-Holland'],
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '08:00',
      closes: '18:00',
    },
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: 'Saturday',
      opens: '09:00',
      closes: '16:00',
    },
  ],
  priceRange: '$$',
};
---

<!doctype html>
<html lang="nl" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="nl_NL" />
    <meta property="og:site_name" content="Lekkage Expert" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <JsonLd data={localBusinessSchema} />
    {schema && <JsonLd data={schema} />}
  </head>
  <body class="font-sans bg-white text-neutral-900 antialiased pb-16 md:pb-0">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <FloatingCTA />
  </body>
</html>
