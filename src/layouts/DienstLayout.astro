---
import Layout from './Layout.astro';
import LeadForm from '../components/LeadForm';

interface Props {
  title: string;
  description: string;
  heroImage?: string;
  serviceType?: string;
  benefits?: string[];
  faq?: { q: string; a: string }[];
}

const {
  title,
  description,
  heroImage = '',
  serviceType = title,
  benefits = [],
  faq = [],
} = Astro.props;

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title,
  description,
  provider: {
    '@type': 'LocalBusiness',
    name: 'Lekkage Expert',
    telephone: '+31854001969',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Vaasahof 29',
      addressLocality: 'Rotterdam',
      postalCode: '3067 DX',
      addressCountry: 'NL',
    },
  },
  areaServed: 'Zuid-Holland',
  serviceType,
};
---

<Layout title={`${title} | Lekkage Expert`} description={description} schema={serviceSchema}>
  <div class="relative h-72 lg:h-96 overflow-hidden bg-gradient-to-r from-primary-950 to-primary-800">
    <div class="absolute inset-0 flex items-center">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
        <nav class="text-primary-200 text-sm mb-4 flex items-center gap-2">
          <a href="/" class="hover:text-white transition-colors">Home</a>
          <span>/</span>
          <a href="/diensten/" class="hover:text-white transition-colors">Diensten</a>
          <span>/</span>
          <span class="text-white">{title}</span>
        </nav>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white max-w-2xl leading-tight">{title}</h1>
      </div>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
      <div class="lg:col-span-2">
        <p class="text-xl text-neutral-600 leading-relaxed mb-8">{description}</p>

        <slot />

        {benefits.length > 0 && (
          <div class="mt-10">
            <h2 class="text-2xl font-bold text-neutral-900 mb-5">Voordelen van onze aanpak</h2>
            <ul class="space-y-3">
              {benefits.map(b => (
                <li class="flex items-start gap-3">
                  <svg class="w-5 h-5 text-secondary-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                  </svg>
                  <span class="text-neutral-700">{b}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        {faq.length > 0 && (
          <div class="mt-12">
            <h2 class="text-2xl font-bold text-neutral-900 mb-6">Veelgestelde vragen</h2>
            <div class="space-y-4">
              {faq.map(item => (
                <details class="group border border-neutral-200 rounded-xl overflow-hidden">
                  <summary class="flex items-center justify-between p-5 cursor-pointer font-semibold text-neutral-800 hover:bg-neutral-50 transition-colors">
                    {item.q}
                    <svg class="w-5 h-5 text-neutral-500 group-open:rotate-180 transition-transform flex-shrink-0 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </summary>
                  <div class="px-5 pb-5 text-neutral-600 leading-relaxed border-t border-neutral-100 pt-4">
                    {item.a}
                  </div>
                </details>
              ))}
            </div>
          </div>
        )}
      </div>

      <div>
        <div class="lg:sticky lg:top-24 space-y-6">
          <LeadForm client:load />
          <div class="bg-primary-50 rounded-2xl p-6 border border-primary-100">
            <h3 class="font-bold text-neutral-900 mb-3">Direct contact</h3>
            <div class="space-y-2">
              <a href="tel:0854001969" class="flex items-center gap-2 text-primary-700 font-semibold hover:text-primary-800 transition-colors">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
                085-4001969
              </a>
              <a href="https://wa.me/31612892333" class="flex items-center gap-2 text-secondary-600 font-semibold hover:text-secondary-700 transition-colors">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                  <path d="M12 0C5.373 0 0 5.373 0 12s5.373 12 12 12 12-5.373 12-12S18.627 0 12 0zm6.231 17.733c-.826 2.35-3.045 3.867-5.569 3.867-1.438 0-2.818-.447-3.969-1.29l-4.412 1.156 1.18-4.297C4.399 15.814 4 14.461 4 13.045 4 8.05 8.05 4 13.045 4c2.447 0 4.747.952 6.476 2.681A9.1 9.1 0 0121.09 13.1c-.001 1.754-.486 3.453-1.405 4.949l.546.684z"/>
                </svg>
                WhatsApp
              </a>
              <a href="mailto:info@lekkageexpert.nl" class="flex items-center gap-2 text-neutral-600 hover:text-neutral-800 transition-colors text-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
                info@lekkageexpert.nl
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
